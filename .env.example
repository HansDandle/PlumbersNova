# Copy to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/plumbersnova"

# JWT secret — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-string"

# Twilio (for SMS / missed-call automation)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Groq (for AI SMS lead intake — free tier at console.groq.com)
GROQ_API_KEY=

# Resend (for emailing invoices — free tier at resend.com)
RESEND_API_KEY=
# Must be a verified domain in Resend, e.g. invoices@yourdomain.com
RESEND_FROM_EMAIL=invoices@yourdomain.com''

# QuickBooks OAuth (optional)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=

# Xero OAuth (optional)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
